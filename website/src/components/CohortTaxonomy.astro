---
import { WORKFLOWS, AGENT_PATTERNS, PRIMITIVES, MODIFIERS } from '../data/patterns';

interface Props {
  /** If true, shows the growable-taxonomy callout below the lanes. */
  showCallout?: boolean;
  /** Override the heading. Defaults to "Three cohorts, one catalog." */
  heading?: string;
}

const { showCallout = true, heading = 'Three cohorts, one catalog.' } = Astro.props;
const base = import.meta.env.BASE_URL || '/agent-blueprints';
const patterns = [...WORKFLOWS, ...AGENT_PATTERNS];

const cohorts = [
  {
    name: 'Patterns',
    accent: 'bg-amber-400',
    pill: 'bg-amber-50 text-amber-900 border-amber-200 hover:bg-amber-100',
    description: 'Cognitive shapes the control flow can take — workflows where the code drives, agents where the LLM drives.',
    entries: patterns,
    href: `${base}/workflows/`,
    entryUrl: (slug: string) => `${base}/patterns/${slug}/`,
  },
  {
    name: 'Primitives',
    accent: 'bg-sky-400',
    pill: 'bg-sky-50 text-sky-900 border-sky-200 hover:bg-sky-100',
    description: 'Capabilities a pattern draws on — memory across turns, callable tools, agent-discovered skills.',
    entries: PRIMITIVES,
    href: `${base}/primitives/`,
    entryUrl: (slug: string) => `${base}/primitives/${slug}/`,
  },
  {
    name: 'Modifiers',
    accent: 'bg-violet-400',
    pill: 'bg-violet-50 text-violet-900 border-violet-200 hover:bg-violet-100',
    description: 'Orthogonal behaviors layered on top of a pattern — human approval gates, audit logging, retries.',
    entries: MODIFIERS,
    href: `${base}/modifiers/`,
    entryUrl: (slug: string) => `${base}/modifiers/${slug}/`,
  },
];
---

<div class="not-prose">
  {heading && (
    <h2 class="font-display font-bold text-xl tracking-display text-text mb-2">
      {heading}
    </h2>
  )}

  <div class="grid md:grid-cols-3 gap-4 mt-4">
    {cohorts.map((cohort) => (
      <div class="bg-bg border border-surface-border rounded-xl p-5">
        <div class="flex items-center gap-2 mb-2">
          <div class={`w-2 h-2 rounded-full ${cohort.accent}`}></div>
          <h3 class="font-display font-bold text-base tracking-display text-text">
            {cohort.name}
          </h3>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">
          {cohort.description}
        </p>
        <div class="flex flex-wrap gap-1.5">
          {cohort.entries.map((entry) => (
            <a
              href={cohort.entryUrl(entry.slug)}
              class={`inline-block px-2.5 py-1 text-xs font-mono rounded-md border transition-colors ${cohort.pill}`}
            >
              {entry.name}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  {showCallout && (
    <p class="mt-5 text-xs text-text-tertiary font-mono leading-relaxed">
      The cohorts and entries can grow. <code class="text-text-secondary">taxonomy.yaml</code> and <code class="text-text-secondary">patterns-catalog.yaml</code> at the repo root are the authoritative source — if the site is behind, trust the catalog.
    </p>
  )}
</div>
