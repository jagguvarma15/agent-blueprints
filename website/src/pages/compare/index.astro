---
import FullWidthLayout from '../../layouts/FullWidthLayout.astro';
import ComparisonTable from '../../components/ComparisonTable';
import DecisionFlowchart from '../../components/DecisionFlowchart';
import { PATTERN_COMPARISONS } from '../../data/patterns';

const base = import.meta.env.BASE_URL || '/agent-blueprints';
---

<FullWidthLayout
  title="Compare Patterns"
  description="Compare all 12 patterns across complexity, latency, cost, and use cases."
>
  <div class="max-w-diagram mx-auto px-6 py-12">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="font-display font-bold text-4xl tracking-display text-text mb-3">
        Compare Patterns
      </h1>
      <p class="text-text-secondary text-lg">
        Sort, filter, and explore all 12 patterns across key attributes. Click a row to expand details.
      </p>
    </div>

    <!-- Comparison table -->
    <section class="mb-16">
      <ComparisonTable client:load patterns={PATTERN_COMPARISONS} base={base} />
    </section>

    <!-- Decision flowchart -->
    <section>
      <div class="mb-6">
        <h2 class="font-display font-bold text-2xl tracking-display text-text mb-2">
          Not sure which pattern to use?
        </h2>
        <p class="text-text-secondary">
          Answer a few questions to get a pattern recommendation.
        </p>
      </div>

      <DecisionFlowchart client:load base={base} />
    </section>
  </div>
</FullWidthLayout>
