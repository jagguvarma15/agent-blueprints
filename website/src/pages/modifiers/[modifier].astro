---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComplexityBadge from '../../components/ComplexityBadge.astro';
import TierTabs from '../../components/TierTabs';
import TableOfContents from '../../components/TableOfContents';
import { MODIFIERS, getPatternById } from '../../data/patterns';
import { readMarkdown, extractHeadings } from '../../utils/content';
import { renderMarkdown } from '../../utils/markdown';
import AntiCompositionWarning from '../../components/AntiCompositionWarning.astro';

export async function getStaticPaths() {
  return MODIFIERS.map((p) => ({
    params: { modifier: p.slug },
    props: { pattern: p },
  }));
}

const { pattern } = Astro.props;
const base = import.meta.env.BASE_URL || '/agent-blueprints';

const overviewMd = readMarkdown(`modifiers/${pattern.id}/overview.md`);
const designMd = readMarkdown(`modifiers/${pattern.id}/design.md`);
const implMd = readMarkdown(`modifiers/${pattern.id}/implementation.md`);
const evolutionMd = readMarkdown(`modifiers/${pattern.id}/evolution.md`);
const observabilityMd = readMarkdown(`modifiers/${pattern.id}/observability.md`);
const costLatencyMd = readMarkdown(`modifiers/${pattern.id}/cost-and-latency.md`);

const overviewHtml = overviewMd ? renderMarkdown(overviewMd) : null;
const designHtml = designMd ? renderMarkdown(designMd) : null;
const implHtml = implMd ? renderMarkdown(implMd) : null;
const evolutionHtml = evolutionMd ? renderMarkdown(evolutionMd) : null;
const observabilityHtml = observabilityMd ? renderMarkdown(observabilityMd) : null;
const costLatencyHtml = costLatencyMd ? renderMarkdown(costLatencyMd) : null;

const allHeadings = {
  overview: overviewMd ? extractHeadings(overviewMd) : [],
  design: designMd ? extractHeadings(designMd) : [],
  implementation: implMd ? extractHeadings(implMd) : [],
  evolution: evolutionMd ? extractHeadings(evolutionMd) : [],
  observability: observabilityMd ? extractHeadings(observabilityMd) : [],
  'cost-latency': costLatencyMd ? extractHeadings(costLatencyMd) : [],
};

const ALL_TABS = [
  { id: 'overview' as const, label: 'Overview', html: overviewHtml },
  { id: 'design' as const, label: 'Design', html: designHtml },
  { id: 'implementation' as const, label: 'Implementation', html: implHtml },
  { id: 'evolution' as const, label: 'Evolution', html: evolutionHtml },
  { id: 'observability' as const, label: 'Observability', html: observabilityHtml },
  { id: 'cost-latency' as const, label: 'Cost & Latency', html: costLatencyHtml },
];
const tabs = ALL_TABS.filter((t) => t.html).map(({ id, label }) => ({ id, label }));

const appliesTo = (pattern.appliesTo ?? [])
  .filter((id) => id !== 'any')
  .map((id) => getPatternById(id))
  .filter(Boolean);
const appliesToAny = (pattern.appliesTo ?? []).includes('any');
---

<DocsLayout
  title={pattern.name}
  description={pattern.description}
  currentPattern={pattern.slug}
  currentCategory="modifier"
>
  <div class="flex gap-8">
    <div class="flex-1 min-w-0">
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full bg-violet-400"></div>
          <span class="text-xs font-mono text-text-tertiary uppercase tracking-wider">Modifier</span>
        </div>
        <h1 class="font-display font-bold text-4xl tracking-display text-text mb-3">
          {pattern.name}
        </h1>
        <p class="text-lg text-text-secondary mb-4">{pattern.description}</p>

        <div class="flex flex-wrap items-center gap-3">
          <ComplexityBadge complexity={pattern.complexity} />

          {appliesToAny && (
            <span class="text-sm text-text-secondary font-mono">
              <span class="text-text-tertiary">Applies to:</span> any pattern
            </span>
          )}
          {!appliesToAny && appliesTo.length > 0 && (
            <span class="flex items-center gap-1.5 text-sm text-text-secondary font-mono">
              <span class="text-text-tertiary">Applies to:</span>
              {appliesTo.map((p, i) => (
                <>
                  <a href={`${base}/patterns/${p!.slug}/`} class="text-accent hover:text-accent-hover transition-colors">
                    {p!.name}
                  </a>
                  {i < appliesTo.length - 1 && <span class="text-text-tertiary">·</span>}
                </>
              ))}
            </span>
          )}
        </div>
      </div>

      <TierTabs
        client:load
        tabs={tabs}
        defaultTier="overview"
        content={{
          overview: overviewHtml ?? undefined,
          design: designHtml ?? undefined,
          implementation: implHtml ?? undefined,
          evolution: evolutionHtml ?? undefined,
          observability: observabilityHtml ?? undefined,
          'cost-latency': costLatencyHtml ?? undefined,
        }}
      />

      <AntiCompositionWarning entryId={pattern.id} />
    </div>

    <div class="w-toc flex-shrink-0 hidden xl:block">
      <TableOfContents client:load allHeadings={allHeadings} defaultTier="overview" />
    </div>
  </div>
</DocsLayout>
