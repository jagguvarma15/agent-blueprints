---
import FullWidthLayout from '../../layouts/FullWidthLayout.astro';
import EvolutionExplorer from '../../components/EvolutionExplorer';
import { WORKFLOWS, AGENT_PATTERNS, EVOLUTION_EDGES } from '../../data/patterns';

const base = import.meta.env.BASE_URL || '/agent-blueprints';
---

<FullWidthLayout
  title="Evolution Explorer"
  description="Visualize how each LLM workflow pattern evolves into agent patterns."
>
  <div class="max-w-diagram mx-auto px-6 py-12">
    <div class="mb-10 text-center">
      <h1 class="font-display font-bold text-4xl tracking-display text-text mb-3">
        Workflow → Agent Evolution
      </h1>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Every agent pattern evolves from a workflow. When conditional logic becomes too complex to hardcode,
        the LLM takes over flow control.
      </p>
    </div>

    <EvolutionExplorer
      client:load
      workflows={WORKFLOWS}
      agentPatterns={AGENT_PATTERNS}
      evolutionEdges={EVOLUTION_EDGES}
      base={base}
    />
  </div>
</FullWidthLayout>
