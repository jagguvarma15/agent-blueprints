---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ComplexityBadge from '../../components/ComplexityBadge.astro';
import TierTabs from '../../components/TierTabs';
import TableOfContents from '../../components/TableOfContents';
import { PRIMITIVES, getPatternById } from '../../data/patterns';
import { buildLevelDocs } from '../../utils/levels';
import AntiCompositionWarning from '../../components/AntiCompositionWarning.astro';

export async function getStaticPaths() {
  return PRIMITIVES.map((p) => ({
    params: { primitive: p.slug },
    props: { pattern: p },
  }));
}

const { pattern } = Astro.props;
const base = import.meta.env.BASE_URL || '/agent-blueprints';

// pattern.id is the on-disk directory name; pattern.slug is the dashed URL.
const { tabs, content, headings } = buildLevelDocs(`primitives/${pattern.id}`);

const parents = (pattern.evolvesFrom ?? [])
  .map((id) => getPatternById(id))
  .filter(Boolean);
---

<DocsLayout
  title={pattern.name}
  description={pattern.description}
  currentPattern={pattern.slug}
  currentCategory="primitive"
>
  <div class="flex gap-8">
    <div class="flex-1 min-w-0">
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-2 h-2 rounded-full bg-sky-400"></div>
          <span class="text-xs font-mono text-text-tertiary uppercase tracking-wider">Primitive</span>
        </div>
        <h1 class="font-display font-bold text-4xl tracking-display text-text mb-3">
          {pattern.name}
        </h1>
        <p class="text-lg text-text-secondary mb-4">{pattern.description}</p>

        <div class="flex flex-wrap items-center gap-3">
          <ComplexityBadge complexity={pattern.complexity} />

          {parents.length > 0 && (
            <span class="flex items-center gap-1.5 text-sm text-text-secondary font-mono">
              <span class="text-text-tertiary">Evolves from:</span>
              {parents.map((p, i) => (
                <>
                  <a href={`${base}/patterns/${p!.slug}/`} class="text-accent hover:text-accent-hover transition-colors">
                    {p!.name}
                  </a>
                  {i < parents.length - 1 && <span class="text-text-tertiary">+</span>}
                </>
              ))}
            </span>
          )}
        </div>
      </div>

      <TierTabs
        client:load
        tabs={tabs}
        defaultTier="overview"
        content={content}
      />

      <AntiCompositionWarning entryId={pattern.id} />
    </div>

    <div class="w-toc flex-shrink-0 hidden xl:block">
      <TableOfContents client:load allHeadings={headings} defaultTier="overview" />
    </div>
  </div>
</DocsLayout>
