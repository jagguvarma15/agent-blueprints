---
import DocsLayout from '../../layouts/DocsLayout.astro';
import TableOfContents from '../../components/TableOfContents';
import { readMarkdown, extractHeadings, extractTitle } from '../../utils/content';
import { renderMarkdown } from '../../utils/markdown';

const md = readMarkdown('meta/changelog.md');
const html = md ? renderMarkdown(md) : null;
const title = md ? extractTitle(md) : 'Changelog';
const headings = md ? extractHeadings(md) : [];
---

<DocsLayout title={title} description="A record of significant changes to the repository by release date.">
  <div class="flex gap-8">
    <div class="flex-1 min-w-0">
      {html ? (
        <div class="prose-content" set:html={html} />
      ) : (
        <p class="text-text-secondary">Content not found.</p>
      )}
    </div>
    <div class="w-toc flex-shrink-0 hidden xl:block">
      <TableOfContents client:load headings={headings} />
    </div>
  </div>
</DocsLayout>
