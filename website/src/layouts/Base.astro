---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Architecture-first patterns for building LLM workflow and agent systems.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL || '/agent-blueprints';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="generator" content={Astro.generator} />

    <title>{title} — Agent Blueprints</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} — Agent Blueprints`} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-bg text-text font-body">
    <slot />

    <!-- Mermaid initialization -->
    <script>
      import mermaid from 'mermaid';
      mermaid.initialize({
        startOnLoad: true,
        theme: 'base',
        themeVariables: {
          primaryColor: '#F5F5F4',
          primaryTextColor: '#1A1A1A',
          primaryBorderColor: '#E7E5E4',
          lineColor: '#9CA3AF',
          secondaryColor: '#FAFAF9',
          tertiaryColor: '#FFFFFF',
          background: '#FFFFFF',
          mainBkg: '#F5F5F4',
          nodeBorder: '#E7E5E4',
          clusterBkg: '#FAFAF9',
          titleColor: '#1A1A1A',
          edgeLabelBackground: '#FFFFFF',
          fontFamily: 'IBM Plex Sans, system-ui, sans-serif',
          fontSize: '13px',
        },
        flowchart: {
          curve: 'basis',
          padding: 20,
        },
      });
    </script>
  </body>
</html>
