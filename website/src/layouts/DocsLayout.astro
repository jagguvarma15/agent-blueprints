---
import Base from './Base.astro';
import Navbar from '../components/Navbar.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  currentPattern?: string;
  currentCategory?: 'workflow' | 'agent';
}

const { title, description, currentPattern, currentCategory } = Astro.props;
---

<Base title={title} description={description}>
  <div class="min-h-screen flex flex-col">
    <Navbar />

    <div class="flex-1 max-w-landing mx-auto w-full px-6">
      <div class="flex gap-12 py-8">
        <!-- Left sidebar -->
        <Sidebar currentPattern={currentPattern} currentCategory={currentCategory} />

        <!-- Main content — data-pagefind-body scopes search indexing to this area -->
        <main class="flex-1 min-w-0 animate-fade-up" data-pagefind-body>
          <slot />
        </main>
      </div>
    </div>

    <Footer />
  </div>
</Base>
